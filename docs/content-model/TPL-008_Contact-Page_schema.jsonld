{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ContactPage",
      "@id": "https://pomegranate.marketing/contact/",
      "url": "https://pomegranate.marketing/contact/",
      "name": "{{pages.meta_title}}",
      "description": "{{pages.meta_description}}",
      "inLanguage": "en-GB",
      "isFamilyFriendly": "true",
      "datePublished": "{{pages.created_at | ISO 8601}}",
      "dateModified": "{{pages.updated_at | ISO 8601}}",
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://pomegranate.marketing/#website",
        "url": "https://pomegranate.marketing/",
        "name": "pomegranate"
      },
      "primaryImageOfPage": {
        "@id": "https://pomegranate.marketing/contact/#primaryimage"
      },
      "image": {
        "@id": "https://pomegranate.marketing/contact/#primaryimage"
      },
      "breadcrumb": {
        "@id": "https://pomegranate.marketing/contact/#breadcrumb"
      },
      "mainEntity": {
        "@id": "https://pomegranate.marketing/contact/#contactpoint"
      },
      "about": [
        {
          "@id": "https://pomegranate.marketing/#organization"
        }
      ],
      "mentions": [
        {
          "@type": "Thing",
          "name": "Customer service",
          "sameAs": [
            "https://en.wikipedia.org/wiki/Customer_service",
            "https://www.wikidata.org/wiki/Q828012"
          ]
        }
      ]
    },
    {
      "@type": "ContactPoint",
      "@id": "https://pomegranate.marketing/contact/#contactpoint",
      "url": "https://pomegranate.marketing/contact/",
      "telephone": "{{businesses.telephone}}",
      "email": "{{businesses.email}}",
      "contactType": "customer service",
      "areaServed": "GB",
      "availableLanguage": "English"
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://pomegranate.marketing/contact/#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@id": "https://pomegranate.marketing/",
            "name": "Home"
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Contact"
        }
      ]
    },
    {
      "@type": "ImageObject",
      "@id": "https://pomegranate.marketing/contact/#primaryimage",
      "url": "{{pages.og_image_url}}",
      "contentUrl": "{{pages.og_image_url}}",
      "width": "{{og_image_width}}",
      "height": "{{og_image_height}}"
    }
  ]
}

{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://pomegranate.marketing/blog/example-blog-post/",
      "url": "https://pomegranate.marketing/blog/example-blog-post/",
      "name": "{{pages.meta_title}}",
      "description": "{{pages.meta_description}}",
      "inLanguage": "en-GB",
      "isFamilyFriendly": "true",
      "datePublished": "{{pages.created_at | ISO 8601}}",
      "dateModified": "{{pages.updated_at | ISO 8601}}",
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://pomegranate.marketing/#website",
        "url": "https://pomegranate.marketing/",
        "name": "pomegranate"
      },
      "primaryImageOfPage": {
        "@id": "https://pomegranate.marketing/blog/example-blog-post/#primaryimage"
      },
      "image": {
        "@id": "https://pomegranate.marketing/blog/example-blog-post/#primaryimage"
      },
      "breadcrumb": {
        "@id": "https://pomegranate.marketing/blog/example-blog-post/#breadcrumb"
      },
      "mainEntity": {
        "@id": "https://pomegranate.marketing/blog/example-blog-post/#article"
      }
    },
    {
      "@type": "BlogPosting",
      "@id": "https://pomegranate.marketing/blog/example-blog-post/#article",
      "mainEntityOfPage": {
        "@id": "https://pomegranate.marketing/blog/example-blog-post/"
      },
      "url": "https://pomegranate.marketing/blog/example-blog-post/",
      "headline": "{{pages.h1_headline}}",
      "articleBody": "{{pages.article_body}}",
      "datePublished": "{{pages.created_at | ISO 8601}}",
      "dateModified": "{{pages.updated_at | ISO 8601}}",
      "articleSection": "{{category.name}}",
      "wordCount": "{{pages.word_count}}",
      "author": {
        "@type": "Person",
        "name": "{{author.name}}",
        "jobTitle": "{{author.job_title}}",
        "description": "{{author.description}}",
        "url": "https://pomegranate.marketing/about/#{{author.slug}}",
        "sameAs": [
          "{{author.linkedin_url}}",
          "{{author.twitter_url}}"
        ],
        "knowsAbout": [
          {
            "@type": "Thing",
            "name": "Search engine optimization",
            "sameAs": "https://www.wikidata.org/wiki/Q180711"
          },
          {
            "@type": "Thing",
            "name": "Digital marketing",
            "sameAs": "https://www.wikidata.org/wiki/Q1321787"
          }
        ]
      },
      "publisher": {
        "@id": "https://pomegranate.marketing/#organization"
      },
      "image": {
        "@id": "https://pomegranate.marketing/blog/example-blog-post/#primaryimage"
      },
      "about": [
        {
          "@type": "Thing",
          "name": "Search engine optimization",
          "sameAs": [
            "https://en.wikipedia.org/wiki/Search_engine_optimization",
            "https://www.wikidata.org/wiki/Q180711"
          ]
        }
      ],
      "mentions": [
        {
          "@type": "Thing",
          "name": "Content marketing",
          "sameAs": [
            "https://en.wikipedia.org/wiki/Content_marketing",
            "https://www.wikidata.org/wiki/Q178274"
          ]
        }
      ],
      "subjectOf": {
        "@id": "https://pomegranate.marketing/blog/example-blog-post/#faq"
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://pomegranate.marketing/blog/example-blog-post/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "{{faq_question_1}}",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{faq_answer_1}}"
          }
        },
        {
          "@type": "Question",
          "name": "{{faq_question_2}}",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{faq_answer_2}}"
          }
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://pomegranate.marketing/blog/example-blog-post/#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@id": "https://pomegranate.marketing/",
            "name": "Home"
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": {
            "@id": "https://pomegranate.marketing/blog/",
            "name": "Blog"
          }
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "{{pages.breadcrumb_name}}"
        }
      ]
    },
    {
      "@type": "ImageObject",
      "@id": "https://pomegranate.marketing/blog/example-blog-post/#primaryimage",
      "url": "{{pages.og_image_url}}",
      "contentUrl": "{{pages.og_image_url}}",
      "width": "{{og_image_width}}",
      "height": "{{og_image_height}}"
    }
  ]
}

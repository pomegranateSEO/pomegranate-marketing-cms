{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": [
        "WebPage",
        "CollectionPage"
      ],
      "@id": "https://pomegranate.marketing/downloads/",
      "url": "https://pomegranate.marketing/downloads/",
      "name": "{{pages.meta_title}}",
      "description": "{{pages.meta_description}}",
      "inLanguage": "en-GB",
      "isFamilyFriendly": "true",
      "datePublished": "{{pages.created_at | ISO 8601}}",
      "dateModified": "{{pages.updated_at | ISO 8601}}",
      "isPartOf": {
        "@type": "WebSite",
        "@id": "https://pomegranate.marketing/#website",
        "url": "https://pomegranate.marketing/",
        "name": "pomegranate"
      },
      "primaryImageOfPage": {
        "@id": "https://pomegranate.marketing/downloads/#primaryimage"
      },
      "image": {
        "@id": "https://pomegranate.marketing/downloads/#primaryimage"
      },
      "breadcrumb": {
        "@id": "https://pomegranate.marketing/downloads/#breadcrumb"
      },
      "about": [
        {
          "@type": "Thing",
          "name": "White paper",
          "sameAs": [
            "https://en.wikipedia.org/wiki/White_paper",
            "https://www.wikidata.org/wiki/Q223706"
          ]
        },
        {
          "@type": "Thing",
          "name": "E-book",
          "sameAs": [
            "https://en.wikipedia.org/wiki/E-book",
            "https://www.wikidata.org/wiki/Q128093"
          ]
        }
      ],
      "mentions": [
        {
          "@type": "Thing",
          "name": "Digital marketing",
          "sameAs": [
            "https://en.wikipedia.org/wiki/Digital_marketing",
            "https://www.wikidata.org/wiki/Q1321787"
          ]
        },
        {
          "@type": "Thing",
          "name": "Search engine optimization",
          "sameAs": [
            "https://en.wikipedia.org/wiki/Search_engine_optimization",
            "https://www.wikidata.org/wiki/Q180711"
          ]
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://pomegranate.marketing/downloads/#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@id": "https://pomegranate.marketing/",
            "name": "Home"
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Downloads"
        }
      ]
    },
    {
      "@type": "ImageObject",
      "@id": "https://pomegranate.marketing/downloads/#primaryimage",
      "url": "{{pages.og_image_url}}",
      "contentUrl": "{{pages.og_image_url}}",
      "width": "{{og_image_width}}",
      "height": "{{og_image_height}}"
    }
  ]
}
